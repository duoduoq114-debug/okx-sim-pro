*{box-sizing:border-box}body{margin:0;background:#050505;color:#f2f4f7;font-family:Arial,'Microsoft YaHei',sans-serif}header{height:62px;display:flex;align-items:center;gap:28px;padding:0 22px;border-bottom:1px solid #20242a;background:#080808;position:sticky;top:0;z-index:2}.brand{font-size:24px;font-weight:900}.brand span{color:#00d395}nav{color:#9aa4b2;flex:1;word-spacing:18px}button{border:0;border-radius:8px;padding:10px 14px;cursor:pointer;font-weight:700}#fundBtn,.buy{background:#00d395;color:#001b13}.sell{background:#ff4d4f;color:#fff}main{display:grid;grid-template-columns:230px 1fr;min-height:calc(100vh - 62px)}aside{border-right:1px solid #20242a;padding:18px;background:#0b0d10}.sym{padding:13px;border-radius:10px;display:flex;justify-content:space-between;cursor:pointer;color:#d7dde6}.sym:hover,.sym.active{background:#181c22}.trade{padding:18px}.top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px}h1{margin:0 0 6px}.balance{background:#11151b;border:1px solid #20242a;border-radius:12px;padding:14px;min-width:220px;line-height:1.8}.grid{display:grid;grid-template-columns:2fr 340px;gap:14px}.card{background:#0e1116;border:1px solid #20242a;border-radius:14px;padding:14px}.chart{height:390px}.form input{width:100%;padding:13px;border-radius:8px;border:1px solid #2a3038;background:#050505;color:#fff;margin-bottom:10px}.form button{width:49%;margin-right:1%}.wide{grid-column:1/3}table{width:100%;border-collapse:collapse}th,td{padding:10px;border-bottom:1px solid #20242a;text-align:left;color:#cdd5df}.bid{color:#00d395}.ask{color:#ff6567}.hint{color:#8b95a1;font-size:13px}@media(max-width:900px){main{grid-template-columns:1fr}aside{border-right:0}.grid{grid-template-columns:1fr}.wide{grid-column:auto}.top{display:block}}
